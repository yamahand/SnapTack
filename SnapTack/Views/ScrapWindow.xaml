<Window x:Class="SnapTack.Views.ScrapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="OnKeyDown"
        MouseDown="OnMouseDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseWheel="OnMouseWheel">
    <Grid>
        <!-- キャプチャ画像 (物理px)。ウィンドウは同じ物理サイズの DIP なので等倍表示になる -->
        <Image x:Name="ScrapImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />
        <!-- サイコロ状態のサムネイル。UniformToFill (AlignmentX/Y=Center) で中央クロップになる -->
        <Rectangle x:Name="DiceThumb" Visibility="Collapsed">
            <Rectangle.Fill>
                <ImageBrush x:Name="DiceBrush" Stretch="UniformToFill" />
            </Rectangle.Fill>
        </Rectangle>
        <!-- 枠線 1px (グレー系)。サイズに含めず画像の縁に重ねることで、元の画面位置とピッタリ重なる -->
        <Rectangle Stroke="#FF808080"
                   StrokeThickness="1"
                   IsHitTestVisible="False" />
    </Grid>
</Window>
