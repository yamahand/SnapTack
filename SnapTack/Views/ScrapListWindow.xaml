<Window x:Class="SnapTack.Views.ScrapListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ThemeMode="System"
        Width="640" Height="480"
        MinWidth="360" MinHeight="280"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Window.Resources>
        <!-- グリッド: 96x96 サムネイルのカード。中央クロップは UniformToFill で行う -->
        <DataTemplate x:Key="GridItemTemplate">
            <Border Width="112" Margin="6" Padding="6"
                    Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <!-- 中央クロップ: 固定サイズの Border でクリップし、Image を UniformToFill で埋める。
                         ImageBrush への直接バインドは DataContext を継承できず警告が出るため Image を使う -->
                    <Border Width="96" Height="96" HorizontalAlignment="Center" ClipToBounds="True">
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Center"
                               Margin="0,4,0,0" FontSize="11" />
                    <TextBlock Text="{Binding StateText}" HorizontalAlignment="Center"
                               FontSize="10" Opacity="0.7" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- リスト: 小さめサムネイル + 日時・サイズ・状態を横並び -->
        <DataTemplate x:Key="ListItemTemplate">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="48" Height="48" ClipToBounds="True">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="{Binding CapturedAtText}" />
                    <TextBlock Text="{Binding SizeText}" FontSize="11" Opacity="0.75" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding StateText}" VerticalAlignment="Center"
                           Margin="10,0,0,0" FontSize="11" Opacity="0.7" />
            </Grid>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="GridPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="ListPanel">
            <StackPanel Orientation="Vertical" />
        </ItemsPanelTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ツールバー: タブ (スクラップ/ゴミ箱) + レイアウト切替 -->
        <Grid DockPanel.Dock="Top" Margin="8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ScrapsTab" GroupName="Tab" IsChecked="True"
                             Checked="OnTabChanged" Margin="0,0,6,0" MinWidth="80" />
                <RadioButton x:Name="TrashTab" GroupName="Tab"
                             Checked="OnTabChanged" MinWidth="80" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <RadioButton x:Name="GridLayoutButton" GroupName="Layout"
                             Checked="OnLayoutChanged" Margin="0,0,6,0" MinWidth="64" />
                <RadioButton x:Name="ListLayoutButton" GroupName="Layout"
                             Checked="OnLayoutChanged" MinWidth="64" />
            </StackPanel>
        </Grid>

        <!-- 空メッセージ (項目が無いとき前面に出す) -->
        <Grid>
            <ListBox x:Name="ItemsList"
                     SelectionMode="Extended"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Center"
                     KeyDown="OnListKeyDown"
                     MouseDoubleClick="OnListMouseDoubleClick" />
            <TextBlock x:Name="EmptyText"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320"
                       Opacity="0.6" Visibility="Collapsed" />
        </Grid>
    </DockPanel>
</Window>
